<div id="<%= dom_id post %>">
  <p>
    <strong>Title:</strong>
    <%= post.title %>
  </p>

  <p>
    <strong>User:</strong>
    <%= post.user.username%>
  </p>

  <p>
    <strong>Post topic:</strong>
    <%= post.post_topic.title %>
  </p>

  <p>
    <strong>Content:</strong>
    <%= post.content %>
  </p>

  <%= render partial: "shared/like_button",
            locals: { record: post, parent: nil } %>



              <% if action_name != "show" %>
    <%= link_to "Show this post", post, class: "" %>
    <%= link_to "Edit this post", edit_post_path(post), class: "" %>
    <hr class="mt-6">
  <% end %>
</div>
